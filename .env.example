# 服务端端口
PORT=3000

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner
DEEPSEEK_THINKING_BODY={"reasoning_effort":"high","thinking":{"type":"enabled"}}
# 也支持追加编号模型：
# DEEPSEEK_MODEL_1=deepseek-v4-flash

# 智谱 GLM
GLM_API_KEY=your-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus
GLM_MODELS=glm-4-plus,glm-4-air,glm-4-flash,glm-4-long
GLM_THINKING_BODY={}
# GLM_MODEL_1=glm-4.5

# 任意 OpenAI-compatible 服务
CUSTOM_API_KEY=sk-your-custom-key
CUSTOM_BASE_URL=https://your-provider.example.com/v1
CUSTOM_CHAT_PATH=/chat/completions
CUSTOM_MODEL=your-model-name
CUSTOM_MODELS=your-model-name,another-model-name
CUSTOM_THINKING_BODY={"enable_thinking":true}
# CUSTOM_MODEL_1=third-model-name

# MySQL read-only query support
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=readonly_user
MYSQL_PASSWORD=readonly_password
MYSQL_DATABASE=your_database
MYSQL_QUERY_TIMEOUT_MS=10000
MYSQL_MAX_ROWS=200
